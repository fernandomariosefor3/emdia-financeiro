{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test:whatsapp-unit": "tsx --test src/whatsapp/__tests__/signature.test.ts src/whatsapp/__tests__/verification.test.ts src/whatsapp/__tests__/parser.test.ts src/whatsapp/__tests__/categories.test.ts src/whatsapp/__tests__/sendMessage.test.ts",
    "test:whatsapp-emulator": "firebase emulators:exec --only firestore \"tsx --test src/whatsapp/__tests__/linking.test.ts && tsx --test src/whatsapp/__tests__/commands.test.ts && tsx --test src/whatsapp/__tests__/webhook.test.ts\"",
    "test:billing-unit": "tsx --test src/billing/__tests__/config.test.ts",
    "test:billing-emulator": "firebase emulators:exec --only firestore \"tsx --test src/billing/__tests__/webhook.test.ts\"",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^5.0.0",
    "openai": "^4.28.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "private": true
}
